DATABASE_URL="postgresql://neondbOwner:***@host.neon.tech/neondb?sslmode=require&channel_binding=require"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk Authentication — get these from https://dashboard.clerk.com
# For Next.js, use Keyless mode (no keys needed in dev). Clerk auto-generates them.
# For production, set these explicitly:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk OAuth — configure Google in the Clerk Dashboard
# https://dashboard.clerk.com → User & Authentication → Social Connections → Google
